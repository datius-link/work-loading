# Use "http://localhost:5000/api" only if you'll always open the admin panel
# from the same machine the backend runs on. To test from a phone/other
# device on the same Wi-Fi, use that machine's LAN IP instead, e.g.
# http://192.168.1.133:5000/api (see mobile/.env for the same requirement).
VITE_API_BASE_URL=http://localhost:5000/api
# Must match ADMIN_API_PREFIX in node/.env (without the /api part, since
# VITE_API_BASE_URL already ends in /api).
VITE_ADMIN_API_PREFIX=/x7k-ops
