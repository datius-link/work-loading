DB_CLIENT=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ekazi
DB_USER=postgres
DB_PASSWORD=change-me-local-db-password

VERIFY_TOKEN_SECRET=change-me-verify-token-secret
AUTH_TOKEN_SECRET=change-me-auth-token-secret
ADMIN_TOKEN_SECRET=change-me-admin-token-secret

# Non-obvious mount path for the admin panel API (kept out of "/api/admin"
# on purpose). Change this to your own value and keep the web app's
# VITE_ADMIN_API_PREFIX in sync with it.
ADMIN_API_PREFIX=/api/x7k-ops

# Required to access /api-docs and /api-docs.json.
SWAGGER_USERNAME=docs-admin
SWAGGER_PASSWORD=change-this-docs-password

# Optional SMTP for sending OTP emails (verify email / password reset).
# Leave unset to fall back to logging codes in the server console/logs.
# Free option: Brevo (brevo.com, 300 emails/day) — after signing up, get
# SMTP credentials from Settings > SMTP & API. EMAIL_FROM must be a sender
# address you verified on the provider.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login
# SMTP_PASS=your-brevo-smtp-key
# EMAIL_FROM=Work Loading <you@gmail.com>
