{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B6B63"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dmcaltd.ekazi"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B6B63"
      },
      "usesCleartextTraffic": true,
      "package": "com.dmcaltd.ekazi",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow e-kazi to use the camera for job workspace photos and videos.",
          "microphonePermission": "Allow e-kazi to use the microphone when recording job workspace videos."
        }
      ],
      "expo-video",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#0B6B63"
        }
      ]
    ]
  }
}
